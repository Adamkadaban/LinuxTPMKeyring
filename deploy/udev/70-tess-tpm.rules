# Grant access to the TPM 2.0 character devices so a non-root user can run
# `tess enroll`/`unlock`/`status`, which talk to the kernel resource manager at /dev/tpmrm0:
#  - TAG+="uaccess": systemd-logind grants the *active seat* login user an ACL automatically — the
#    normal graphical/console flow needs no group change at all. The `70-` prefix is chosen so this
#    runs BEFORE systemd's 73-seat-late.rules, which is what actually applies the uaccess tag.
#  - MODE 0660 + GROUP tss: a headless/SSH/service fallback for users who are not on an active seat
#    (add them to the `tss` group). Ownership is left to the default (root) — tess provisions the
#    `tss` group but not a `tss` user.
# See udev(7) and systemd's uaccess mechanism.
KERNEL=="tpm[0-9]*", TAG+="systemd", TAG+="uaccess", MODE="0660", GROUP="tss"
KERNEL=="tpmrm[0-9]*", TAG+="systemd", TAG+="uaccess", MODE="0660", GROUP="tss"
