# Rust / Cargo
/target
**/target
Cargo.lock.orig
*.rs.bk

# Reference repos — read-only context, never committed
/references/

# Secrets / keys / TPM artifacts — never commit
*.pem
*.key
*.priv
*.pub.tpm
id_*
*_rsa
*_ed25519
*.sealed
*.blob
recovery-secret*
.env
.env.*
!.env.example

# Azure / deploy local state
deploy/azure/.terraform/
deploy/azure/*.tfstate*
deploy/**/local.*

# swtpm / test state
/testing/**/state/
*.tpmstate

# Local QEMU contributor VM state (images, seeds, sockets, pidfiles)
/deploy/qemu/.run/

# Fuzzing — ignore the fuzzer-generated corpus growth (libFuzzer names its additions by content
# hash, no extension) and crash artifacts, but keep the curated, extension-named seed inputs.
**/fuzz/corpus/**
!**/fuzz/corpus/*/
!**/fuzz/corpus/*/*.json
!**/fuzz/corpus/*/*.bin
!**/fuzz/corpus/*/*.txt
**/fuzz/artifacts/

# OS / editor junk
.DS_Store
Thumbs.db
*.swp
*~
.idea/
.vscode/
